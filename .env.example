# 复制成 .env 后填写（.env 已被 gitignore）

# OpenAI API key（AI 功能必填）：https://platform.openai.com/ 创建（注意：与 ChatGPT 订阅无关，需单独充值）
OPENAI_API_KEY=

# 模型（默认 gpt-5.1；想省钱可换 gpt-5-mini）
# OPENAI_MODEL=gpt-5.1

# 访问密码：部署到公网后必填，本地开发不设就不启用登录
# APP_PASSWORD=

# Postgres 连接串（Vercel + Neon 时由集成自动注入，本地不设则用 ./.pglite 文件数据库）
# DATABASE_URL=

# 时区，决定"今天/本周"怎么算（默认 Australia/Sydney）
# APP_TZ=Australia/Sydney
